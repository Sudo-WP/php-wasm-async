+/*
+ * php-wasm-async (Session 6): generalized to string payload/return.
+ * fp_async_call is implemented in JS (source/library_fp_async.js) and linked
+ * as a WebAssembly import; it is listed in ASYNCIFY_IMPORTS so it is capable
+ * of suspending the PHP stack. The JS side allocates the return string via
+ * stringToNewUTF8 (_malloc); the caller frees it after copying to PHP's heap.
+ * See docs/DECISIONS.md ADR-0016.
+ */
+extern char* fp_async_call(const char* payload);
+
 int main(void) { return 0; }
 
 bool started = false;
@@ -283,6 +293,41 @@ char* EMSCRIPTEN_KEEPALIVE pib_tokenize(char *code)
 	ZEND_PARSE_PARAMETERS_END()
 #endif
 
+/*
+ * php-wasm-async (Session 6): expose fp_async_call to PHP userspace as
+ * fp_async_call(string $payload): string. The JS side allocates the return
+ * string with stringToNewUTF8; we copy it into PHP's heap and free the
+ * wasm-heap allocation. Non-strict PHP type coercion means integer literals
+ * still work (41 → "41"), preserving existing Node V8 regression tests.
+ * See docs/DECISIONS.md ADR-0016.
+ */
+ZEND_BEGIN_ARG_WITH_RETURN_TYPE_INFO_EX(arginfo_fp_async_call, 0, 1, IS_STRING, 0)
+	ZEND_ARG_TYPE_INFO(0, payload, IS_STRING, 0)
+ZEND_END_ARG_INFO()
+
+PHP_FUNCTION(fp_async_call)
+{
+	char *payload;
+	size_t payload_len;
+
+	ZEND_PARSE_PARAMETERS_START(1, 1)
+		Z_PARAM_STRING(payload, payload_len)
+	ZEND_PARSE_PARAMETERS_END();
+
+	char *result = fp_async_call(payload);
+	if (result != NULL) {
+		RETVAL_STRING(result);
+		free(result);
+	} else {
+		RETURN_EMPTY_STRING();
+	}
+}
+
+static const zend_function_entry pib_functions[] = {
+	PHP_FE(fp_async_call, arginfo_fp_async_call)
+	PHP_FE_END
+};
+
 PHP_RINIT_FUNCTION(pib)
 {
 	return SUCCESS;
@@ -306,7 +351,7 @@ PHP_MINFO_FUNCTION(pib)
 zend_module_entry pib_module_entry = {
 	STANDARD_MODULE_HEADER,
 	"pib",
-	NULL,                    /* zend_function_entry */
+	pib_functions,           /* zend_function_entry (php-wasm-async: fp_async_call) */
 	PHP_MINIT(pib),          /* PHP_MINIT - Module initialization */
 	NULL,                    /* PHP_MSHUTDOWN - Module shutdown */
 	PHP_RINIT(pib),          /* PHP_RINIT - Request initialization */
