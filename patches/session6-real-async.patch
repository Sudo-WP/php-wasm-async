diff --git a/source/library_fp_async.js b/source/library_fp_async.js
new file mode 100644
index 00000000..058df7d5
--- /dev/null
+++ b/source/library_fp_async.js
@@ -0,0 +1,57 @@
+// fp_async_call — the php-wasm-async async host-call bridge import.
+//
+// php-wasm-async, Session 6. Generalizes the Session 3 int→int stub to a
+// generic registered-handler mechanism with string payload and string return.
+//
+// Design rule: this file must stay store-agnostic. It does not know what KV,
+// D1, or R2 are. It delegates to Module.hostAsyncCall, set per-request by the
+// Worker. See DESIGN.md and DECISIONS.md ADR-0016.
+//
+// Handler dispatch:
+//   - If Module.hostAsyncCall is a function, call it with the payload string
+//     and await the result. Used in workerd with a real KV (or other) handler.
+//   - Otherwise, fall back to the old setTimeout(0) stub: parseInt(payload)+1
+//     as a string. This keeps all prior Node V8 regression tests passing
+//     without modification (fp_async_call(41) → "42").
+//
+// String marshalling (Session 6 change from int→int):
+//   - Incoming payload: read via UTF8ToString(payloadPtr) from wasm heap.
+//   - Return value: allocate in wasm heap via stringToNewUTF8(result); the C
+//     side (pib.c PHP_FUNCTION) copies to PHP's heap and calls free().
+//
+// Ordering markers are logged to stderr so the suspend/resume sequence is
+// unambiguous in test output.
+//
+// Apache-2.0, the php-wasm-async authors. Original work, not derived from any
+// GPL source; merged into the Emscripten JS library at link time.
+
+mergeInto(LibraryManager.library, {
+	// char* fp_async_call(const char* payload)
+	fp_async_call__async: true,
+	fp_async_call: function (payloadPtr) {
+		const payload = UTF8ToString(payloadPtr);
+		return Asyncify.handleAsync(async () => {
+			console.error('[fp_async_call] invoked payload=' + payload);
+			let result;
+			if (typeof Module.hostAsyncCall === 'function') {
+				console.error('[fp_async_call] delegating to Module.hostAsyncCall');
+				const value = await Module.hostAsyncCall(payload);
+				result = (value != null) ? String(value) : '';
+			} else {
+				// Fallback stub: keeps Node V8 regression tests working
+				// (fp_async_call(41) → "42"). Not used in workerd when a
+				// real KV handler is registered.
+				result = await new Promise(resolve => {
+					console.error('[fp_async_call] promise registered, returning control to host');
+					setTimeout(() => {
+						const value = String((parseInt(payload, 10) || 0) + 1);
+						console.error('[fp_async_call] timer fired, resolving promise -> ' + value);
+						resolve(value);
+					}, 0);
+				});
+			}
+			console.error('[fp_async_call] wasm resumed, returning ' + result);
+			return stringToNewUTF8(result);
+		});
+	},
+});
diff --git a/source/pib/pib.c b/source/pib/pib.c
