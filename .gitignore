# Build artifacts — large generated/compiled files
*.o
*.a
dist/
node_modules/

# Large generated wasm/js binaries (NOT the committed 31-byte trampoline)
worker/build/php*-worker.mjs
worker/build/php*-worker.mjs.wasm
worker/build/smoke-*.mjs

# Temporary single-version smoke-test config (Session 8 per-version verification)
wrangler.smoke.toml

# trampoline-vp.wasm IS committed: it is a small (31 B), deterministic file
# that wrangler must bundle at AOT compile time. Not generated by the upstream
# pipeline — created once, version-controlled with the worker source.
# (Do NOT add *.wasm here; it would also ignore trampoline-vp.wasm)

# Secrets & local config
.dev.vars
.wrangler/
*.log

# OS / editor cruft
*:Zone.Identifier
.DS_Store
